<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GalaxyTunnel" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/gt_primary</item>
        <item name="colorPrimaryVariant">@color/gt_primary_dark</item>
        <item name="colorOnPrimary">@color/gt_text_primary</item>
        <item name="android:windowBackground">@color/gt_background</item>
        <item name="android:statusBarColor">@color/gt_surface</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="GalaxyTunnel.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/gt_surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <style name="GalaxyTunnel.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/gt_primary</item>
        <item name="android:textColor">@color/gt_text_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="GalaxyTunnel.ProgressBar" parent="Widget.AppCompat.ProgressBar">
        <item name="android:indeterminateTint">@color/gt_primary</item>
    </style>
</resources>
