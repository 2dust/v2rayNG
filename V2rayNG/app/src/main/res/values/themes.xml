<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Manus Choice: Charcoal & Gold (Always Dark Theme) -->
    <style name="AppThemeDayNight" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Main colors (Charcoal Black Background) -->
        <item name="colorPrimary">@color/simpsons_gold</item>
        <item name="colorOnPrimary">@color/charcoal_black</item>
        <item name="colorPrimaryContainer">@color/charcoal_surface</item>
        <item name="colorOnPrimaryContainer">@color/simpsons_gold</item>
        
        <item name="colorSecondary">@color/simpsons_gold_dark</item>
        <item name="colorOnSecondary">@color/charcoal_black</item>
        <item name="colorSecondaryContainer">@color/charcoal_black</item>
        <item name="colorOnSecondaryContainer">@color/simpsons_gold</item>
        
        <item name="android:windowBackground">@color/charcoal_black</item>
        <item name="android:statusBarColor">@color/charcoal_black</item>
        <item name="android:navigationBarColor">@color/charcoal_black</item>
        
        <!-- Surface and background colors -->
        <item name="android:colorBackground">@color/charcoal_black</item>
        <item name="colorSurface">@color/charcoal_surface</item>
        <item name="colorOnSurface">@color/parchment_white</item>
        <item name="colorSurfaceVariant">@color/charcoal_black</item>
        <item name="colorOnSurfaceVariant">@color/parchment_grey</item>
        
        <item name="colorOutline">@color/simpsons_gold_dark</item>
        
        <!-- Typography -->
        <item name="android:textColor">@color/parchment_white</item>
        <item name="android:textColorSecondary">@color/parchment_grey</item>
        
        <!-- Tab Layout styling -->
        <item name="tabIndicatorColor">@color/simpsons_gold</item>
        <item name="tabSelectedTextColor">@color/simpsons_gold</item>
        <item name="tabTextColor">@color/parchment_grey</item>
    </style>

    <!-- AppThemeBase required by other activities and resources -->
    <style name="AppThemeBase" parent="AppThemeDayNight" />

    <style name="AppThemeDayNight.NoActionBar" parent="AppThemeDayNight">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppThemeDayNight.NoActionBar.Translucent" parent="AppThemeDayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="BrandedSwitch" parent="AppThemeDayNight">
        <item name="colorPrimary">@color/simpsons_gold</item>
    </style>
</resources>
