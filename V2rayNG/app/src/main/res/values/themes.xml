<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="AppThemeDayNight" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main colors -->
        <item name="colorPrimary">@color/simpsons_yellow</item>
        <item name="colorOnPrimary">@color/medieval_dark</item>
        <item name="colorPrimaryContainer">@color/simpsons_yellow_dirty</item>
        <item name="colorOnPrimaryContainer">@color/medieval_dark</item>
        
        <item name="colorSecondary">@color/medieval_brown</item>
        <item name="colorOnSecondary">@color/parchment</item>
        <item name="colorSecondaryContainer">@color/medieval_dark</item>
        <item name="colorOnSecondaryContainer">@color/simpsons_yellow</item>
        
        <item name="android:windowBackground">@color/medieval_dark</item>
        <item name="android:statusBarColor">@color/medieval_dark</item>
        <item name="android:navigationBarColor">@color/medieval_dark</item>
        
        <!-- Surface and background colors -->
        <item name="android:colorBackground">@color/medieval_dark</item>
        <item name="colorSurface">@color/medieval_brown</item>
        <item name="colorOnSurface">@color/simpsons_yellow</item>
        <item name="colorSurfaceVariant">#3E2723</item>
        <item name="colorOnSurfaceVariant">@color/simpsons_yellow_dirty</item>
        
        <item name="colorOutline">@color/simpsons_yellow_dirty</item>
        
        <!-- Typography -->
        <item name="android:textColor">@color/simpsons_yellow</item>
        <item name="android:textColorSecondary">@color/simpsons_yellow_dirty</item>
    </style>

    <style name="AppThemeDayNight.NoActionBar" parent="AppThemeDayNight">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppThemeDayNight.NoActionBar.Translucent" parent="AppThemeDayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="BrandedSwitch" parent="AppThemeDayNight">
        <item name="colorPrimary">@color/simpsons_yellow</item>
    </style>
</resources>
