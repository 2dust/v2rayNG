<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (Medieval Dark with Yellow Highlights). -->
    <!-- Forcing Dark theme for full Nightly mode compatibility. -->
    <style name="AppThemeDayNight" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Main colors (Medieval Dark Background) -->
        <item name="colorPrimary">@color/simpsons_yellow</item>
        <item name="colorOnPrimary">@color/medieval_dark</item>
        <item name="colorPrimaryContainer">@color/medieval_brown</item>
        <item name="colorOnPrimaryContainer">@color/parchment</item>
        
        <item name="colorSecondary">@color/medieval_brown_light</item>
        <item name="colorOnSecondary">@color/medieval_dark</item>
        <item name="colorSecondaryContainer">@color/medieval_dark</item>
        <item name="colorOnSecondaryContainer">@color/simpsons_yellow</item>
        
        <item name="android:windowBackground">@color/medieval_dark</item>
        <item name="android:statusBarColor">@color/medieval_dark</item>
        <item name="android:navigationBarColor">@color/medieval_dark</item>
        
        <!-- Surface and background colors -->
        <item name="android:colorBackground">@color/medieval_dark</item>
        <item name="colorSurface">@color/medieval_brown</item>
        <item name="colorOnSurface">@color/parchment</item>
        <item name="colorSurfaceVariant">@color/medieval_dark</item>
        <item name="colorOnSurfaceVariant">@color/parchment_dark</item>
        
        <item name="colorOutline">@color/medieval_brown_light</item>
        
        <!-- Typography -->
        <item name="android:textColor">@color/parchment</item>
        <item name="android:textColorSecondary">@color/parchment_dark</item>
        
        <!-- Tab Layout styling -->
        <item name="tabIndicatorColor">@color/simpsons_yellow</item>
        <item name="tabSelectedTextColor">@color/simpsons_yellow</item>
        <item name="tabTextColor">@color/parchment_dark</item>
    </style>

    <!-- AppThemeBase required by other activities and resources -->
    <style name="AppThemeBase" parent="AppThemeDayNight" />

    <style name="AppThemeDayNight.NoActionBar" parent="AppThemeDayNight">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppThemeDayNight.NoActionBar.Translucent" parent="AppThemeDayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="BrandedSwitch" parent="AppThemeDayNight">
        <item name="colorPrimary">@color/simpsons_yellow</item>
    </style>
</resources>
