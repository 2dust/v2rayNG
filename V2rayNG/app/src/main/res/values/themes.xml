<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (Vibrant Yellow with Medieval Dark Text). -->
    <style name="AppThemeDayNight" parent="Theme.Material3.Light.NoActionBar">
        <!-- Main colors (Yellow Background) -->
        <item name="colorPrimary">@color/medieval_brown</item>
        <item name="colorOnPrimary">@color/simpsons_yellow</item>
        <item name="colorPrimaryContainer">@color/simpsons_yellow_dirty</item>
        <item name="colorOnPrimaryContainer">@color/medieval_dark</item>
        
        <item name="colorSecondary">@color/simpsons_yellow_dirty</item>
        <item name="colorOnSecondary">@color/medieval_dark</item>
        <item name="colorSecondaryContainer">@color/parchment</item>
        <item name="colorOnSecondaryContainer">@color/medieval_dark</item>
        
        <item name="android:windowBackground">@color/simpsons_yellow</item>
        <item name="android:statusBarColor">@color/simpsons_yellow</item>
        <item name="android:navigationBarColor">@color/simpsons_yellow</item>
        
        <!-- Surface and background colors -->
        <item name="android:colorBackground">@color/simpsons_yellow</item>
        <item name="colorSurface">@color/simpsons_yellow</item>
        <item name="colorOnSurface">@color/medieval_dark</item>
        <item name="colorSurfaceVariant">@color/simpsons_yellow_dirty</item>
        <item name="colorOnSurfaceVariant">@color/medieval_dark</item>
        
        <item name="colorOutline">@color/medieval_brown</item>
        
        <!-- Typography -->
        <item name="android:textColor">@color/medieval_dark</item>
        <item name="android:textColorSecondary">@color/medieval_brown</item>
        
        <!-- Tab Layout styling -->
        <item name="tabIndicatorColor">@color/medieval_brown</item>
        <item name="tabSelectedTextColor">@color/medieval_dark</item>
        <item name="tabTextColor">@color/medieval_brown</item>
    </style>

    <style name="AppThemeDayNight.NoActionBar" parent="AppThemeDayNight">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppThemeDayNight.NoActionBar.Translucent" parent="AppThemeDayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="BrandedSwitch" parent="AppThemeDayNight">
        <item name="colorPrimary">@color/medieval_brown</item>
    </style>
</resources>
