<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Medieval Base Palette (Dominant Dark) -->
    <color name="medieval_dark">#1A120B</color> <!-- Fundo Principal (Couro Escuro/Pedra) -->
    <color name="medieval_brown">#3C2A21</color> <!-- Fundo Secundário (Madeira/Couro) -->
    <color name="medieval_brown_light">#D4A373</color> <!-- Destaques em Castanho Claro -->
    <color name="medieval_red">#7B1113</color> <!-- Vermelho Sangue Medieval para Erros -->
    <color name="parchment">#E6D5B8</color> <!-- Cor de Pergaminho para Textos Principais -->
    <color name="parchment_dark">#B2A58D</color> <!-- Pergaminho Escurecido para Textos Secundários -->

    <!-- Simpsons Yellow as Support/Highlight -->
    <color name="simpsons_yellow">#FFD90F</color> <!-- Cor de Destaque (Botões Ativos, Indicadores) -->
    <color name="simpsons_yellow_dirty">#CCAD00</color> <!-- Amarelo Ouro para Detalhes Menores -->
    
    <color name="colorPing">#00C853</color> <!-- Verde para Ping Bom -->
    <color name="colorPingRed">@color/medieval_red</color>
    <color name="colorConfigType">@color/simpsons_yellow_dirty</color>
    <color name="colorWhite">#FFFFFF</color>
    <color name="color_fab_active">@color/simpsons_yellow</color> <!-- FAB Amarelo sobre fundo Escuro -->
    <color name="color_fab_inactive">#5D4037</color>
    <color name="divider_color_light">#2D2018</color>
    <color name="colorIndicator">@color/simpsons_yellow</color>

    <!-- Material Theme Mapping (Sempre Dark para compatibilidade Nightly) -->
    <color name="md_theme_primary">@color/simpsons_yellow</color>
    <color name="md_theme_onPrimary">@color/medieval_dark</color>
    <color name="md_theme_primaryContainer">@color/medieval_brown</color>
    <color name="md_theme_onPrimaryContainer">@color/parchment</color>

    <color name="md_theme_secondary">@color/medieval_brown_light</color>
    <color name="md_theme_onSecondary">@color/medieval_dark</color>
    <color name="md_theme_secondaryContainer">@color/medieval_dark</color>
    <color name="md_theme_onSecondaryContainer">@color/simpsons_yellow</color>

    <color name="md_theme_background">@color/medieval_dark</color>
    <color name="md_theme_onBackground">@color/parchment</color>

    <color name="md_theme_surface">@color/medieval_brown</color>
    <color name="md_theme_onSurface">@color/parchment</color>
    <color name="md_theme_surfaceVariant">@color/medieval_dark</color>
    <color name="md_theme_onSurfaceVariant">@color/parchment_dark</color>
    
    <color name="md_theme_outline">@color/medieval_brown_light</color>
    <color name="md_theme_error">@color/medieval_red</color>
</resources>
