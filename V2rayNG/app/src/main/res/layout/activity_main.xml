<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/simpsons_sky"
    tools:context=".ui.MainActivity">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Background Clouds (Animated) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            
            <ImageView
                android:id="@+id/cloud1"
                android:layout_width="120dp"
                android:layout_height="80dp"
                android:layout_marginTop="40dp"
                android:alpha="0.8"
                android:src="@drawable/ic_cartoon_cloud" />

            <ImageView
                android:id="@+id/cloud2"
                android:layout_width="180dp"
                android:layout_height="120dp"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="160dp"
                android:alpha="0.8"
                android:src="@drawable/ic_cartoon_cloud" />

            <ImageView
                android:id="@+id/cloud3"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="100dp"
                android:layout_marginStart="40dp"
                android:alpha="0.8"
                android:src="@drawable/ic_cartoon_cloud" />
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp">

            <!-- Header Title (Floating Style) -->
            <FrameLayout
                android:id="@+id/header_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="20dp"
                android:rotation="-2"
                android:background="@drawable/bg_neobrutalist_header"
                android:paddingHorizontal="24dp"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SIMPSONS VPN"
                    android:textColor="@color/black"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
            </FrameLayout>

            <!-- Settings Button (Gear) -->
            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_neobrutalist_card"
                android:contentDescription="Settings"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_settings_24dp" />

            <!-- Main Content Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/header_container"
                android:layout_marginTop="48dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <!-- Status Indicator -->
                <LinearLayout
                    android:id="@+id/statusContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_neobrutalist_status"
                    android:gravity="center"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/iv_status_icon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_fab_check"
                        app:tint="@color/black" />

                    <TextView
                        android:id="@+id/tv_test_state"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="DISCONNECTED"
                        android:textColor="@color/black"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Big Connect Button (The Power Button) -->
                <FrameLayout
                    android:id="@+id/btn_connect_container"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_marginTop="40dp">

                    <View
                        android:id="@+id/fab"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_neobrutalist_connect_button" />

                    <ImageView
                        android:id="@+id/ivPowerIcon"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:layout_gravity="center"
                        android:layout_marginBottom="6dp"
                        android:layout_marginEnd="6dp"
                        android:src="@drawable/ic_play_24dp"
                        app:tint="@color/black" />
                </FrameLayout>

                <!-- Server Selection Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT LOCATION"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/server_selection_card"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_neobrutalist_card"
                        android:gravity="center_vertical"
                        android:padding="20dp">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_neobrutalist_header"
                            android:padding="10dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_play_24dp"
                                app:tint="@color/black" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_server_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SELECT SERVER"
                                android:textColor="@color/black"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_server_ping"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ping: --"
                                android:textColor="#88000000"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_play_24dp"
                            app:tint="@color/black" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Hidden components to maintain original code functionality -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/view_pager"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

        </RelativeLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Navigation Drawer (Hidden) -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:visibility="gone" />

</androidx.drawerlayout.widget.DrawerLayout>
