<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gt_background"
    tools:context=".ui.MainActivity">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/gt_background"
        android:elevation="0dp"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/gt_background"
            app:title="@string/gt_app_name"
            app:titleTextColor="@color/gt_text_primary"
            app:titleTextAppearance="@style/GalaxyTunnel.Text.Title"
            app:navigationIcon="@drawable/ic_menu"
            app:menu="@menu/menu_main" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Connection Status Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/gt_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <!-- Status Text -->
                    <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/gt_status_disconnected"
                        android:textColor="@color/gt_disconnected"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Status Indicator -->
                    <View
                        android:id="@+id/status_indicator"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/gt_status_indicator"
                        android:layout_marginBottom="24dp" />

                    <!-- VPN Toggle Button -->
                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/btn_vpn_toggle"
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:background="@drawable/gt_circle_button"
                        android:src="@drawable/ic_power"
                        android:scaleType="centerInside"
                        android:padding="32dp"
                        android:contentDescription="@string/gt_btn_connect" />

                    <!-- Connection Info -->
                    <TextView
                        android:id="@+id/tv_server_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/gt_error_no_server"
                        android:textColor="@color/gt_text_secondary"
                        android:textSize="14sp"
                        android:layout_marginTop="16dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stats Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/gt_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <!-- Download Stat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_download"
                            android:tint="@color/gt_primary" />

                        <TextView
                            android:id="@+id/tv_download_speed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 B/s"
                            android:textColor="@color/gt_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/gt_stats_download"
                            android:textColor="@color/gt_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Upload Stat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_upload"
                            android:tint="@color/gt_primary" />

                        <TextView
                            android:id="@+id/tv_upload_speed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 B/s"
                            android:textColor="@color/gt_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/gt_stats_upload"
                            android:textColor="@color/gt_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Duration Stat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_timer"
                            android:tint="@color/gt_primary" />

                        <TextView
                            android:id="@+id/tv_duration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00:00"
                            android:textColor="@color/gt_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/gt_stats_duration"
                            android:textColor="@color/gt_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Server List Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gt_server_list_title"
                android:textColor="@color/gt_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Server List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_server_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_server_galaxy_tunnel" />

            <!-- Add Server Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_server"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/gt_server_add"
                android:textColor="@color/gt_text_primary"
                android:background="@drawable/gt_button_outline"
                app:icon="@drawable/ic_add"
                app:iconTint="@color/gt_primary"
                app:iconGravity="textStart"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/gt_nav_bg"
        app:itemIconTint="@color/gt_nav_item"
        app:itemTextColor="@color/gt_nav_item"
        app:itemRippleColor="@color/gt_card_ripple"
        app:menu="@menu/menu_bottom_nav" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>