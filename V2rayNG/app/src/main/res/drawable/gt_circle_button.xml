<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/gt_button_primary_pressed"/>
            <stroke android:width="4dp" android:color="@color/gt_primary_dark"/>
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="oval">
            <solid android:color="@color/gt_button_secondary"/>
            <stroke android:width="4dp" android:color="@color/gt_text_disabled"/>
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/gt_button_primary"/>
            <stroke android:width="4dp" android:color="@color/gt_primary"/>
            <size android:width="120dp" android:height="120dp"/>
        </shape>
    </item>
</selector>